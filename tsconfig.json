{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": false,
    "noEmitOnError": true,
    "newLine": "lf",
    "rootDir": "internal/api/web/src",
    "outDir": "internal/api/web/assets"
  },
  "include": ["internal/api/web/src/**/*.ts"]
}
